<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_Simplified_Employee_Onboarding" targetNamespace="https://komgis.com/bpmn/simplified-employee-onboarding" exporter="bpmn-js (https://demo.bpmn.io)" exporterVersion="18.13.2">
  <bpmn:collaboration id="Collaboration_Simplified_Employee_Onboarding">
    <bpmn:participant id="Participant_Onboarding" name="Simplified Employee Onboarding Process" processRef="Process_Simplified_Onboarding" />
  </bpmn:collaboration>
  <bpmn:process id="Process_Simplified_Onboarding" name="Simplified Employee Onboarding Process" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Simplified_Onboarding">
      <bpmn:lane id="Lane_HRIS" name="HRIS / Internal Systems">
        <bpmn:flowNodeRef>Task_Update_Systems</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Manager_IT" name="Manager / IT">
        <bpmn:flowNodeRef>Task_Manager_IT_Setup</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Employee" name="New Employee">
        <bpmn:flowNodeRef>Task_Employee_Submits_Info</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_HR" name="HR / Onboarding Team">
        <bpmn:flowNodeRef>Task_Prepare_Checklist</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Send_Invitation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Review_Info</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Info_Complete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Request_Missing_Info</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Setup_Needed</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Notify_Employee</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_Onboarding_Complete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Start_New_Hire</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:task id="Task_Prepare_Checklist" name="Prepare onboarding checklist">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Send_Invitation" name="Send onboarding invitation">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Employee_Submits_Info" name="Employee submits documents and questions">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:incoming>Flow_7_Loop</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Review_Info" name="Review documents and questions">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_Info_Complete" name="Information complete?">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_6_No</bpmn:outgoing>
      <bpmn:outgoing>Flow_8_Yes</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_Request_Missing_Info" name="Request missing information">
      <bpmn:incoming>Flow_6_No</bpmn:incoming>
      <bpmn:outgoing>Flow_7_Loop</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_Setup_Needed" name="Manager or IT setup needed?">
      <bpmn:incoming>Flow_8_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_9_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_10_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_Manager_IT_Setup" name="Complete manager / IT setup">
      <bpmn:incoming>Flow_9_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Update_Systems" name="Update HRIS and internal systems">
      <bpmn:incoming>Flow_10_No</bpmn:incoming>
      <bpmn:incoming>Flow_11</bpmn:incoming>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Notify_Employee" name="Notify employee onboarding is complete">
      <bpmn:incoming>Flow_12</bpmn:incoming>
      <bpmn:outgoing>Flow_13</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End_Onboarding_Complete" name="Onboarding completed">
      <bpmn:incoming>Flow_13</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_1" sourceRef="Start_New_Hire" targetRef="Task_Prepare_Checklist" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_Prepare_Checklist" targetRef="Task_Send_Invitation" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Task_Send_Invitation" targetRef="Task_Employee_Submits_Info" />
    <bpmn:sequenceFlow id="Flow_7_Loop" sourceRef="Task_Request_Missing_Info" targetRef="Task_Employee_Submits_Info" />
    <bpmn:sequenceFlow id="Flow_4" sourceRef="Task_Employee_Submits_Info" targetRef="Task_Review_Info" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="Task_Review_Info" targetRef="Gateway_Info_Complete" />
    <bpmn:sequenceFlow id="Flow_6_No" name="No" sourceRef="Gateway_Info_Complete" targetRef="Task_Request_Missing_Info" />
    <bpmn:sequenceFlow id="Flow_8_Yes" name="Yes" sourceRef="Gateway_Info_Complete" targetRef="Gateway_Setup_Needed" />
    <bpmn:sequenceFlow id="Flow_9_Yes" name="Yes" sourceRef="Gateway_Setup_Needed" targetRef="Task_Manager_IT_Setup" />
    <bpmn:sequenceFlow id="Flow_10_No" name="No" sourceRef="Gateway_Setup_Needed" targetRef="Task_Update_Systems" />
    <bpmn:sequenceFlow id="Flow_11" sourceRef="Task_Manager_IT_Setup" targetRef="Task_Update_Systems" />
    <bpmn:sequenceFlow id="Flow_12" sourceRef="Task_Update_Systems" targetRef="Task_Notify_Employee" />
    <bpmn:sequenceFlow id="Flow_13" sourceRef="Task_Notify_Employee" targetRef="End_Onboarding_Complete" />
    <bpmn:startEvent id="Start_New_Hire" name="New hire record created">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_Simplified_Onboarding">
    <bpmndi:BPMNPlane id="BPMNPlane_Simplified_Onboarding" bpmnElement="Collaboration_Simplified_Employee_Onboarding">
      <bpmndi:BPMNShape id="Participant_Onboarding_di" bpmnElement="Participant_Onboarding" isHorizontal="true">
        <dc:Bounds x="120" y="100" width="2020" height="600" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_HRIS_di" bpmnElement="Lane_HRIS" isHorizontal="true">
        <dc:Bounds x="150" y="550" width="1990" height="150" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Manager_IT_di" bpmnElement="Lane_Manager_IT" isHorizontal="true">
        <dc:Bounds x="150" y="400" width="1990" height="150" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Employee_di" bpmnElement="Lane_Employee" isHorizontal="true">
        <dc:Bounds x="150" y="250" width="1990" height="150" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_HR_di" bpmnElement="Lane_HR" isHorizontal="true">
        <dc:Bounds x="150" y="100" width="1990" height="150" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Prepare_Checklist_di" bpmnElement="Task_Prepare_Checklist">
        <dc:Bounds x="270" y="135" width="170" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Send_Invitation_di" bpmnElement="Task_Send_Invitation">
        <dc:Bounds x="480" y="135" width="170" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Employee_Submits_Info_di" bpmnElement="Task_Employee_Submits_Info">
        <dc:Bounds x="690" y="285" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Review_Info_di" bpmnElement="Task_Review_Info">
        <dc:Bounds x="910" y="135" width="170" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Info_Complete_di" bpmnElement="Gateway_Info_Complete" isMarkerVisible="true">
        <dc:Bounds x="1120" y="150" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1117" y="116" width="56" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Request_Missing_Info_di" bpmnElement="Task_Request_Missing_Info">
        <dc:Bounds x="1220" y="135" width="170" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Setup_Needed_di" bpmnElement="Gateway_Setup_Needed" isMarkerVisible="true">
        <dc:Bounds x="1430" y="150" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1419" y="116" width="73" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Manager_IT_Setup_di" bpmnElement="Task_Manager_IT_Setup">
        <dc:Bounds x="1420" y="435" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Update_Systems_di" bpmnElement="Task_Update_Systems">
        <dc:Bounds x="1640" y="585" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Notify_Employee_di" bpmnElement="Task_Notify_Employee">
        <dc:Bounds x="1870" y="135" width="170" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_Onboarding_Complete_di" bpmnElement="End_Onboarding_Complete">
        <dc:Bounds x="2070" y="157" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="2059" y="200" width="58" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Start_New_Hire_di" bpmnElement="Start_New_Hire">
        <dc:Bounds x="202" y="157" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="181" y="200" width="78" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="238" y="175" />
        <di:waypoint x="270" y="175" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="440" y="175" />
        <di:waypoint x="480" y="175" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_3_di" bpmnElement="Flow_3">
        <di:waypoint x="650" y="175" />
        <di:waypoint x="670" y="175" />
        <di:waypoint x="670" y="325" />
        <di:waypoint x="690" y="325" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_7_Loop_di" bpmnElement="Flow_7_Loop">
        <di:waypoint x="1220" y="175" />
        <di:waypoint x="1185" y="175" />
        <di:waypoint x="1185" y="265" />
        <di:waypoint x="760" y="265" />
        <di:waypoint x="760" y="285" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_4_di" bpmnElement="Flow_4">
        <di:waypoint x="870" y="325" />
        <di:waypoint x="890" y="325" />
        <di:waypoint x="890" y="175" />
        <di:waypoint x="910" y="175" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_5_di" bpmnElement="Flow_5">
        <di:waypoint x="1080" y="175" />
        <di:waypoint x="1120" y="175" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_6_No_di" bpmnElement="Flow_6_No">
        <di:waypoint x="1145" y="200" />
        <di:waypoint x="1145" y="235" />
        <di:waypoint x="1305" y="235" />
        <di:waypoint x="1305" y="220" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1152" y="207" width="15" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_8_Yes_di" bpmnElement="Flow_8_Yes">
        <di:waypoint x="1158" y="163" />
        <di:waypoint x="1200" y="120" />
        <di:waypoint x="1400" y="120" />
        <di:waypoint x="1443" y="163" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1181" y="140" width="18" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_9_Yes_di" bpmnElement="Flow_9_Yes">
        <di:waypoint x="1455" y="200" />
        <di:waypoint x="1455" y="435" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1461" y="207" width="18" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_10_No_di" bpmnElement="Flow_10_No">
        <di:waypoint x="1480" y="175" />
        <di:waypoint x="1610" y="175" />
        <di:waypoint x="1610" y="625" />
        <di:waypoint x="1640" y="625" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1494" y="153" width="15" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_11_di" bpmnElement="Flow_11">
        <di:waypoint x="1600" y="475" />
        <di:waypoint x="1620" y="475" />
        <di:waypoint x="1620" y="625" />
        <di:waypoint x="1640" y="625" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_12_di" bpmnElement="Flow_12">
        <di:waypoint x="1820" y="625" />
        <di:waypoint x="1850" y="625" />
        <di:waypoint x="1850" y="175" />
        <di:waypoint x="1870" y="175" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_13_di" bpmnElement="Flow_13">
        <di:waypoint x="2040" y="175" />
        <di:waypoint x="2070" y="175" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
