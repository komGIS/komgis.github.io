      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AI_Answer_Questions_di" bpmnElement="Task_AI_Answer_Questions">
        <dc:Bounds x="1680" y="435" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AI_Save_Notify_HR_di" bpmnElement="Task_AI_Save_Notify_HR">
        <dc:Bounds x="1900" y="435" width="190" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Setup_Needed_di" bpmnElement="Gateway_Setup_Needed" isMarkerVisible="true">
        <dc:Bounds x="2140" y="150" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="2129" y="116" width="73" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Manager_IT_Setup_di" bpmnElement="Task_Manager_IT_Setup">
