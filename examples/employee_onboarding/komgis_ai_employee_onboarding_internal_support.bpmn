<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_Onboarding_AI_Layer" targetNamespace="https://komgis.com/bpmn/onboarding-ai-automation" exporter="bpmn-js (https://demo.bpmn.io)" exporterVersion="18.13.2">
  <bpmn:collaboration id="Collaboration_Onboarding_AI_Layer">
    <bpmn:participant id="Participant_Onboarding" name="Employee Onboarding with AI Automation Layer" processRef="Process_Onboarding_AI_Layer" />
  </bpmn:collaboration>
  <bpmn:process id="Process_Onboarding_AI_Layer" name="Employee Onboarding with AI Automation Layer" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Onboarding_AI_Layer">
      <bpmn:lane id="Lane_HR" name="HR / Onboarding Team">
        <bpmn:flowNodeRef>Start_New_Hire</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Prepare_Checklist</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Send_Invitation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Setup_Needed</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Notify_Employee</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_Onboarding_Complete</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Employee" name="New Employee">
        <bpmn:flowNodeRef>Task_Employee_Submits_Info</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_AI" name="AI Automation">
        <bpmn:flowNodeRef>Task_AI_Check_Data</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_AI_Data_Complete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AI_Request_Corrections</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AI_Load_Policies</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AI_Answer_Questions</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AI_Save_Notify_HR</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Manager_IT" name="Manager / IT">
        <bpmn:flowNodeRef>Task_Manager_IT_Setup</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_HRIS" name="HRIS / Internal Systems">
        <bpmn:flowNodeRef>Task_Update_Systems</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="Start_New_Hire" name="New hire record created" />
    <bpmn:task id="Task_Prepare_Checklist" name="Prepare onboarding checklist" />
    <bpmn:task id="Task_Send_Invitation" name="Send onboarding invitation" />
    <bpmn:task id="Task_Employee_Submits_Info" name="Employee fills and submits onboarding form" />
    <bpmn:task id="Task_AI_Check_Data" name="AI checks form fields and documents" />
    <bpmn:exclusiveGateway id="Gateway_AI_Data_Complete" name="Data complete and correct?" />
    <bpmn:task id="Task_AI_Request_Corrections" name="AI asks employee to correct missing data" />
    <bpmn:task id="Task_AI_Load_Policies" name="AI loads policies and role documents" />
    <bpmn:task id="Task_AI_Answer_Questions" name="AI answers onboarding questions" />
    <bpmn:task id="Task_AI_Save_Notify_HR" name="AI saves data and simulates HR email" />
    <bpmn:exclusiveGateway id="Gateway_Setup_Needed" name="Manager or IT setup needed?" />
    <bpmn:task id="Task_Manager_IT_Setup" name="Complete manager / IT setup" />
    <bpmn:task id="Task_Update_Systems" name="Update HRIS and internal systems" />
    <bpmn:sequenceFlow id="Flow_1" sourceRef="Start_New_Hire" targetRef="Task_Prepare_Checklist" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_Prepare_Checklist" targetRef="Task_Send_Invitation" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Task_Send_Invitation" targetRef="Task_Employee_Submits_Info" />
    <bpmn:sequenceFlow id="Flow_4" sourceRef="Task_Employee_Submits_Info" targetRef="Task_AI_Check_Data" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="Task_AI_Check_Data" targetRef="Gateway_AI_Data_Complete" />
    <bpmn:sequenceFlow id="Flow_6_No" name="No" sourceRef="Gateway_AI_Data_Complete" targetRef="Task_AI_Request_Corrections" />
    <bpmn:sequenceFlow id="Flow_7_Loop" sourceRef="Task_AI_Request_Corrections" targetRef="Task_Employee_Submits_Info" />
    <bpmn:sequenceFlow id="Flow_8_Yes" name="Yes" sourceRef="Gateway_AI_Data_Complete" targetRef="Task_AI_Load_Policies" />
    <bpmn:sequenceFlow id="Flow_9" sourceRef="Task_AI_Load_Policies" targetRef="Task_AI_Answer_Questions" />
    <bpmn:sequenceFlow id="Flow_10" sourceRef="Task_AI_Answer_Questions" targetRef="Task_AI_Save_Notify_HR" />
    <bpmn:sequenceFlow id="Flow_11" sourceRef="Task_AI_Save_Notify_HR" targetRef="Gateway_Setup_Needed" />
    <bpmn:sequenceFlow id="Flow_12_Yes" name="Yes" sourceRef="Gateway_Setup_Needed" targetRef="Task_Manager_IT_Setup" />
    <bpmn:sequenceFlow id="Flow_13_No" name="No" sourceRef="Gateway_Setup_Needed" targetRef="Task_Update_Systems" />
    <bpmn:sequenceFlow id="Flow_14" sourceRef="Task_Manager_IT_Setup" targetRef="Task_Update_Systems" />
    <bpmn:sequenceFlow id="Flow_15" sourceRef="Task_Update_Systems" targetRef="Task_Notify_Employee" />
    <bpmn:sequenceFlow id="Flow_16" sourceRef="Task_Notify_Employee" targetRef="End_Onboarding_Complete" />
    <bpmn:task id="Task_Notify_Employee" name="Notify employee onboarding is complete" />
    <bpmn:endEvent id="End_Onboarding_Complete" name="Onboarding completed" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_Onboarding_AI_Layer">
    <bpmndi:BPMNPlane id="BPMNPlane_Onboarding_AI_Layer" bpmnElement="Collaboration_Onboarding_AI_Layer">
      <bpmndi:BPMNShape id="Participant_Onboarding_di" bpmnElement="Participant_Onboarding" isHorizontal="true">
        <dc:Bounds x="120" y="100" width="2680" height="750" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_HRIS_di" bpmnElement="Lane_HRIS" isHorizontal="true">
        <dc:Bounds x="150" y="700" width="2650" height="150" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Manager_IT_di" bpmnElement="Lane_Manager_IT" isHorizontal="true">
        <dc:Bounds x="150" y="550" width="2650" height="150" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_AI_di" bpmnElement="Lane_AI" isHorizontal="true">
        <dc:Bounds x="150" y="400" width="2650" height="150" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Employee_di" bpmnElement="Lane_Employee" isHorizontal="true">
        <dc:Bounds x="150" y="250" width="2650" height="150" />
      </bpmndi:BPMNShape>
