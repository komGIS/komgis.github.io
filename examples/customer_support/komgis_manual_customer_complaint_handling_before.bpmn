<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_Manual_Customer_Complaint_Before_AI" targetNamespace="https://komgis.com/bpmn/manual-customer-complaint-before-ai" exporter="bpmn-js (https://demo.bpmn.io)" exporterVersion="18.13.2">
  <bpmn:process id="Process_Manual_Customer_Complaint_Before_AI" name="Manual Customer Complaint Handling Process Before AI Automation" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Manual_Complaint">
      <bpmn:lane id="Lane_Outbound" name="Outbound Communication">
        <bpmn:flowNodeRef>Task_Send_Response</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_Complaint_Handled</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Manager" name="Support Manager">
        <bpmn:flowNodeRef>Task_Review_Response</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Rework_Response</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Approved</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Support" name="Support Employee">
        <bpmn:flowNodeRef>Task_Read_Complaint</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Categorize_Issue</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Search_History</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Request_Info</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Draft_Response</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Info_Complete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_Additional_Info_Received</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Intake" name="Support Intake">
        <bpmn:flowNodeRef>Task_Register_Complaint</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Assign_Ticket</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Start_Complaint_Received</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="Start_Complaint_Received" name="Complaint received" />
    <bpmn:task id="Task_Register_Complaint" name="Manually register complaint in ticketing system" />
    <bpmn:task id="Task_Assign_Ticket" name="Assign complaint to support employee" />
    <bpmn:userTask id="Task_Read_Complaint" name="Read full complaint manually" />
    <bpmn:userTask id="Task_Categorize_Issue" name="Manually categorize issue and urgency" />
    <bpmn:userTask id="Task_Search_History" name="Search previous customer communication manually" />
    <bpmn:exclusiveGateway id="Gateway_Info_Complete" name="Information complete?" />
    <bpmn:sendTask id="Task_Request_Info" name="Request missing information from customer" />
    <bpmn:intermediateCatchEvent id="Event_Additional_Info_Received" name="Receive additional information" />
    <bpmn:userTask id="Task_Draft_Response" name="Manually draft customer response" />
    <bpmn:userTask id="Task_Review_Response" name="Manager reviews response" />
    <bpmn:exclusiveGateway id="Gateway_Approved" name="Response approved?" />
    <bpmn:userTask id="Task_Rework_Response" name="Rework response based on manager feedback" />
    <bpmn:sendTask id="Task_Send_Response" name="Send approved response to customer" />
    <bpmn:endEvent id="End_Complaint_Handled" name="Complaint response completed" />
    <bpmn:sequenceFlow id="Flow_1" sourceRef="Start_Complaint_Received" targetRef="Task_Register_Complaint" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_Register_Complaint" targetRef="Task_Assign_Ticket" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Task_Assign_Ticket" targetRef="Task_Read_Complaint" />
    <bpmn:sequenceFlow id="Flow_4" sourceRef="Task_Read_Complaint" targetRef="Task_Categorize_Issue" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="Task_Categorize_Issue" targetRef="Task_Search_History" />
    <bpmn:sequenceFlow id="Flow_6" sourceRef="Task_Search_History" targetRef="Gateway_Info_Complete" />
    <bpmn:sequenceFlow id="Flow_7_Yes" name="Yes" sourceRef="Gateway_Info_Complete" targetRef="Task_Draft_Response" />
    <bpmn:sequenceFlow id="Flow_7_No" name="No" sourceRef="Gateway_Info_Complete" targetRef="Task_Request_Info" />
    <bpmn:sequenceFlow id="Flow_8" sourceRef="Task_Request_Info" targetRef="Event_Additional_Info_Received" />
    <bpmn:sequenceFlow id="Flow_9" sourceRef="Event_Additional_Info_Received" targetRef="Task_Search_History" />
    <bpmn:sequenceFlow id="Flow_10" sourceRef="Task_Draft_Response" targetRef="Task_Review_Response" />
    <bpmn:sequenceFlow id="Flow_11" sourceRef="Task_Review_Response" targetRef="Gateway_Approved" />
    <bpmn:sequenceFlow id="Flow_12_Yes" name="Yes" sourceRef="Gateway_Approved" targetRef="Task_Send_Response" />
    <bpmn:sequenceFlow id="Flow_12_No" name="No" sourceRef="Gateway_Approved" targetRef="Task_Rework_Response" />
    <bpmn:sequenceFlow id="Flow_13" sourceRef="Task_Rework_Response" targetRef="Task_Review_Response" />
    <bpmn:sequenceFlow id="Flow_14" sourceRef="Task_Send_Response" targetRef="End_Complaint_Handled" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_Manual_Complaint">
    <bpmndi:BPMNPlane id="BPMNPlane_Manual_Complaint" bpmnElement="Process_Manual_Customer_Complaint_Before_AI">
