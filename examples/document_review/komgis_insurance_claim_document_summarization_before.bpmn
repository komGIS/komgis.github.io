<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_Process_Insurance_Claim_Before_AI" targetNamespace="https://komgis.com/bpmn/insurance-claim" exporter="bpmn-js (https://demo.bpmn.io)" exporterVersion="18.13.2">
  <bpmn:process id="Process_Insurance_Claim_Before_AI" name="Insurance Claim Document Review Before AI Automation" isExecutable="false">
    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_Finance" name="Financial Department">
        <bpmn:flowNodeRef>Task_Email_Finance</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_Approved</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Agent" name="Insurance Agent">
        <bpmn:flowNodeRef>Task_Review_Data</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Read_Documents</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Extract_Facts</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Check_Policy</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Request_Info</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Prepare_Summary</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Reject_Claim</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_Rejected</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Info_Complete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Decision</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Dashboard" name="Claims Dashboard / Back Office">
        <bpmn:flowNodeRef>Task_Register_Claim</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Open_Claim_Dashboard</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Start_Claim_Received</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="Start_Claim_Received" name="Insurance claim received" />
    <bpmn:task id="Task_Register_Claim" name="Register claim and documents" />
    <bpmn:userTask id="Task_Open_Claim_Dashboard" name="Open claim in dashboard" />
    <bpmn:userTask id="Task_Review_Data" name="Review claim, customer and contract data" />
    <bpmn:userTask id="Task_Read_Documents" name="Read documents, forms and images manually" />
    <bpmn:userTask id="Task_Extract_Facts" name="Manually extract relevant claim facts" />
    <bpmn:userTask id="Task_Check_Policy" name="Check insurance policy and company rules" />
    <bpmn:exclusiveGateway id="Gateway_Info_Complete" name="Information complete?" />
    <bpmn:sendTask id="Task_Request_Info" name="Request missing information" />
    <bpmn:userTask id="Task_Prepare_Summary" name="Prepare manual summary and recommendation" />
    <bpmn:exclusiveGateway id="Gateway_Decision" name="Approve or reject?" />
    <bpmn:task id="Task_Reject_Claim" name="Record rejection explanation" />
    <bpmn:endEvent id="End_Rejected" name="Claim rejected" />
    <bpmn:sendTask id="Task_Email_Finance" name="Send approval email to Financial Department" />
    <bpmn:endEvent id="End_Approved" name="Claim approved and sent to finance" />
    <bpmn:sequenceFlow id="F1" sourceRef="Start_Claim_Received" targetRef="Task_Register_Claim" />
    <bpmn:sequenceFlow id="F2" sourceRef="Task_Register_Claim" targetRef="Task_Open_Claim_Dashboard" />
    <bpmn:sequenceFlow id="F3" sourceRef="Task_Open_Claim_Dashboard" targetRef="Task_Review_Data" />
    <bpmn:sequenceFlow id="F4" sourceRef="Task_Review_Data" targetRef="Task_Read_Documents" />
    <bpmn:sequenceFlow id="F5" sourceRef="Task_Read_Documents" targetRef="Task_Extract_Facts" />
    <bpmn:sequenceFlow id="F6" sourceRef="Task_Extract_Facts" targetRef="Task_Check_Policy" />
    <bpmn:sequenceFlow id="F7" sourceRef="Task_Check_Policy" targetRef="Gateway_Info_Complete" />
    <bpmn:sequenceFlow id="F8N" name="No" sourceRef="Gateway_Info_Complete" targetRef="Task_Request_Info" />
    <bpmn:sequenceFlow id="F8Y" name="Yes" sourceRef="Gateway_Info_Complete" targetRef="Task_Prepare_Summary" />
    <bpmn:sequenceFlow id="F9" name="Waiting / incomplete" sourceRef="Task_Request_Info" targetRef="End_Rejected" />
    <bpmn:sequenceFlow id="F10" sourceRef="Task_Prepare_Summary" targetRef="Gateway_Decision" />
    <bpmn:sequenceFlow id="F11A" name="Approve" sourceRef="Gateway_Decision" targetRef="Task_Email_Finance" />
    <bpmn:sequenceFlow id="F12" sourceRef="Task_Email_Finance" targetRef="End_Approved" />
    <bpmn:sequenceFlow id="F11R" name="Reject" sourceRef="Gateway_Decision" targetRef="Task_Reject_Claim" />
    <bpmn:sequenceFlow id="F13" sourceRef="Task_Reject_Claim" targetRef="End_Rejected" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="Diagram_Process_Insurance_Claim_Before_AI">
    <bpmndi:BPMNPlane id="Plane_Process_Insurance_Claim_Before_AI" bpmnElement="Process_Insurance_Claim_Before_AI">
