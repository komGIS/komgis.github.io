<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_Process_Insurance_Claim_AI" targetNamespace="https://komgis.com/bpmn/insurance-claim-ai" exporter="bpmn-js (https://demo.bpmn.io)" exporterVersion="18.13.2">
  <bpmn:process id="Process_Insurance_Claim_AI_Assisted" name="Insurance Claim Document Summarization with AI Automation" isExecutable="false">
    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_Dashboard" name="Claims Dashboard / Back Office">
        <bpmn:flowNodeRef>Start_Claim_Received</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Register_Claim</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Open_Dashboard</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_AI" name="AI Automation">
        <bpmn:flowNodeRef>Task_AI_Load_Documents</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AI_Summarize_Extract</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AI_Answer_Questions</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AI_Policy_Suggestion</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AI_Send_Approval</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AI_Send_Rejection</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Agent" name="Insurance Agent">
        <bpmn:flowNodeRef>Task_Agent_Review</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Decision</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Finance" name="Financial Department">
        <bpmn:flowNodeRef>End_Approved</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_Rejected</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="Start_Claim_Received" name="Insurance claim received" />
    <bpmn:task id="Task_Register_Claim" name="Register claim and documents" />
    <bpmn:userTask id="Task_Open_Dashboard" name="Open claim in dashboard" />
    <bpmn:serviceTask id="Task_AI_Load_Documents" name="AI loads claim documents from database" />
    <bpmn:serviceTask id="Task_AI_Summarize_Extract" name="AI summarizes documents and extracts key data" />
    <bpmn:serviceTask id="Task_AI_Answer_Questions" name="AI answers claim questions from documents" />
    <bpmn:serviceTask id="Task_AI_Policy_Suggestion" name="AI checks company policy and suggests approve or reject" />
    <bpmn:sendTask id="Task_AI_Send_Approval" name="AI simulates approval email to finance" />
    <bpmn:sendTask id="Task_AI_Send_Rejection" name="AI simulates rejection email to finance" />
    <bpmn:userTask id="Task_Agent_Review" name="Agent reviews summary and asks questions" />
    <bpmn:exclusiveGateway id="Gateway_Decision" name="Approve or reject claim?" />
    <bpmn:endEvent id="End_Approved" name="Claim approved and sent to finance" />
    <bpmn:endEvent id="End_Rejected" name="Claim rejected and sent to finance" />
    <bpmn:sequenceFlow id="F1" sourceRef="Start_Claim_Received" targetRef="Task_Register_Claim" />
    <bpmn:sequenceFlow id="F2" sourceRef="Task_Register_Claim" targetRef="Task_Open_Dashboard" />
    <bpmn:sequenceFlow id="F3" sourceRef="Task_Open_Dashboard" targetRef="Task_AI_Load_Documents" />
    <bpmn:sequenceFlow id="F4" sourceRef="Task_AI_Load_Documents" targetRef="Task_AI_Summarize_Extract" />
    <bpmn:sequenceFlow id="F5" sourceRef="Task_AI_Summarize_Extract" targetRef="Task_Agent_Review" />
    <bpmn:sequenceFlow id="F6" sourceRef="Task_Agent_Review" targetRef="Task_AI_Answer_Questions" />
    <bpmn:sequenceFlow id="F7" sourceRef="Task_AI_Answer_Questions" targetRef="Task_AI_Policy_Suggestion" />
    <bpmn:sequenceFlow id="F8" sourceRef="Task_AI_Policy_Suggestion" targetRef="Gateway_Decision" />
    <bpmn:sequenceFlow id="F9A" name="Approve" sourceRef="Gateway_Decision" targetRef="Task_AI_Send_Approval" />
    <bpmn:sequenceFlow id="F10A" sourceRef="Task_AI_Send_Approval" targetRef="End_Approved" />
    <bpmn:sequenceFlow id="F9R" name="Reject" sourceRef="Gateway_Decision" targetRef="Task_AI_Send_Rejection" />
    <bpmn:sequenceFlow id="F10R" sourceRef="Task_AI_Send_Rejection" targetRef="End_Rejected" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Process_Insurance_Claim_AI_Assisted">
      <bpmndi:BPMNShape id="Lane_Finance_di" bpmnElement="Lane_Finance" isHorizontal="true">
        <dc:Bounds x="160" y="560" width="2080" height="130" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Agent_di" bpmnElement="Lane_Agent" isHorizontal="true">
